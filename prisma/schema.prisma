// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}



model Article {
  id              String    @id @default(uuid())
  title           String
  excerpt         String
  content         String
  category        String   // 'weekly-updates', 'daily-feed', 'global-events', 'forex', 'learn-forex'
  publishedAt     DateTime  @default(now())
  author          String
  imageUrl        String
  isFeatured      Boolean   @default(false)
  updatedAt       DateTime  @updatedAt
  status          String    @default("DRAFT") // "DRAFT", "PENDING", "PUBLISHED", "SCHEDULED", "ARCHIVED", "TRASH"
  scheduledAt     DateTime?
  publishedBy     String?
  editedBy        String?
  revisionComment String?
  department      String    @default("Publications")
}

model Sponsor {
  id          String   @id // e.g. "leaderboard", "square", "inline"
  title       String
  description String
  linkUrl     String
  buttonText  String
  imageUrl    String   @default("") // Logo image
  bgImageUrl  String   @default("") // Background image
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model TickerConfig {
  id         String   @id @default("ticker")
  mode       String   @default("auto")      // "auto" (RSS live feed) or "manual" (admin override)
  manualText String   @default("")          // Custom text written by admin (e.g., "Alert 1 | Alert 2")
  updatedAt  DateTime @updatedAt
}

model User {
  id                  String       @id @default(uuid())
  fullName            String
  username            String       @unique
  email               String       @unique
  password            String       // Hashed password
  roleId              String?      // Reference to Role
  role                Role?        @relation(fields: [roleId], references: [id])
  status              String       @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  profilePhoto        String       @default("/images/default-avatar.png")
  departments         Department[] @relation("DeptMembers")
  workspaces          Workspace[]  @relation("WorkspaceMembers")
  supervisedDepartments Department[] @relation("DeptSupervisor")
  actingSupervisedDepartments Department[] @relation("DeptActingSupervisor")
  phone               String       @default("")
  dob                 String       @default("")
  activeSince         DateTime     @default(now())
  lastLogin           DateTime?
  lastActivity        DateTime?
  isOnline            Boolean      @default(false)
  isArchived          Boolean      @default(false)
  createdBy           String       @default("System")
  updatedAt           DateTime     @updatedAt
  forcePasswordChange Boolean      @default(false)
  tempPassword        String       @default("")
  notificationSetting NotificationSetting?
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // OWNER, ADMIN, SUPERVISOR, EMPLOYEE
  users       User[]
}

model Department {
  id                  String    @id @default(uuid())
  name                String    @unique // Publication, Marketing, Research
  supervisorId        String?
  supervisor          User?     @relation("DeptSupervisor", fields: [supervisorId], references: [id])
  members             User[]    @relation("DeptMembers")
  actingSupervisorId  String?
  actingSupervisor    User?     @relation("DeptActingSupervisor", fields: [actingSupervisorId], references: [id])
  actingStart         DateTime?
  actingEnd           DateTime?
  actingReason        String?
  actingAssignedBy    String?
}

model Workspace {
  id      String   @id @default(uuid())
  name    String   @unique // Publication, Marketing, Research
  members User[]   @relation("WorkspaceMembers")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  token     String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  expiresAt DateTime
  revoked   Boolean  @default(false)
}

model AuditLog {
  id          String   @id @default(uuid())
  timestamp   DateTime @default(now())
  username    String
  action      String   // Logged In, Logged Out, Created, Edited, Approved, Published, Scheduled, Archived, Trashed, Restored
  module      String   // ARTICLE, USER, SPONSOR, BREAKING_NEWS, AUTH, SYSTEM
  objectId    String?
  objectName  String?
  result      String   @default("SUCCESS") // SUCCESS, FAILURE
  ipAddress   String?
  details     String?  // JSON string details
}

model Notification {
  id          String   @id @default(uuid())
  timestamp   DateTime @default(now())
  title       String
  description String
  module      String   // ARTICLE, BREAKING_NEWS, SYSTEM, ANNOUNCEMENT
  objectId    String?
  status      String   @default("UNREAD") // UNREAD, READ, ARCHIVED
  username    String   // Target recipient username
}

model NotificationSetting {
  id                    String  @id @default(uuid())
  userId                String  @unique
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  articlesEnabled       Boolean @default(true)
  breakingNewsEnabled   Boolean @default(true)
  announcementsEnabled  Boolean @default(true)
  systemEnabled         Boolean @default(true)
}

model ChatConversation {
  id                  String        @id @default(uuid())
  type                String        // "DIRECT" or "GROUP"
  name                String?       // Group name
  description         String?       // Group description
  createdBy           String?       // Group creator
  createdDate         DateTime      @default(now())
  isArchived          Boolean       @default(false)
  archivedByUsernames String        @default("[]")  // JSON list of usernames who archived this conversation
  deletedByUsernames  String        @default("[]")  // JSON list of usernames who deleted this conversation from their view
  memberUsernames     String        @default("[]")  // JSON list of usernames in direct message or group members
  messages            ChatMessage[]
}

model ChatMessage {
  id              String           @id @default(uuid())
  conversationId  String
  conversation    ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUsername  String
  content         String
  timestamp       DateTime         @default(now())
  readByUsernames String           @default("[]")  // JSON list of usernames who have read this message
  attachmentUrl   String?          // prepared file architecture
  attachmentName  String?          // prepared file architecture
}

model SystemAnnouncement {
  id            String    @id @default(uuid())
  title         String
  message       String
  createdBy     String
  createdDate   DateTime  @default(now())
  expiryDate    DateTime?
  isPinned      Boolean   @default(false)
}
