// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // Hashed password
  createdAt DateTime @default(now())
}

model Article {
  id          String   @id @default(uuid())
  title       String
  excerpt     String
  content     String
  category    String   // 'weekly-updates', 'daily-feed', 'global-events', 'forex', 'learn-forex'
  publishedAt DateTime @default(now())
  author      String
  imageUrl    String
  isFeatured  Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

model Sponsor {
  id          String   @id // e.g. "leaderboard", "square", "inline"
  title       String
  description String
  linkUrl     String
  buttonText  String
  imageUrl    String   @default("") // Logo image
  bgImageUrl  String   @default("") // Background image
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model TickerConfig {
  id         String   @id @default("ticker")
  mode       String   @default("auto")      // "auto" (RSS live feed) or "manual" (admin override)
  manualText String   @default("")          // Custom text written by admin (e.g., "Alert 1 | Alert 2")
  updatedAt  DateTime @updatedAt
}

model User {
  id                  String       @id @default(uuid())
  fullName            String
  username            String       @unique
  email               String       @unique
  password            String       // Hashed password
  roleId              String?      // Reference to Role
  role                Role?        @relation(fields: [roleId], references: [id])
  status              String       @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  profilePhoto        String       @default("/images/default-avatar.png")
  departments         Department[] @relation("DeptMembers")
  workspaces          Workspace[]  @relation("WorkspaceMembers")
  supervisedDepartments Department[] @relation("DeptSupervisor")
  actingSupervisedDepartments Department[] @relation("DeptActingSupervisor")
  phone               String       @default("")
  dob                 String       @default("")
  activeSince         DateTime     @default(now())
  lastLogin           DateTime?
  lastActivity        DateTime?
  isOnline            Boolean      @default(false)
  isArchived          Boolean      @default(false)
  createdBy           String       @default("System")
  updatedAt           DateTime     @updatedAt
  forcePasswordChange Boolean      @default(false)
  tempPassword        String       @default("")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // OWNER, ADMIN, SUPERVISOR, EMPLOYEE
  users       User[]
}

model Department {
  id                  String    @id @default(uuid())
  name                String    @unique // Publication, Marketing, Research
  supervisorId        String?
  supervisor          User?     @relation("DeptSupervisor", fields: [supervisorId], references: [id])
  members             User[]    @relation("DeptMembers")
  actingSupervisorId  String?
  actingSupervisor    User?     @relation("DeptActingSupervisor", fields: [actingSupervisorId], references: [id])
  actingStart         DateTime?
  actingEnd           DateTime?
  actingReason        String?
  actingAssignedBy    String?
}

model Workspace {
  id      String   @id @default(uuid())
  name    String   @unique // Publication, Marketing, Research
  members User[]   @relation("WorkspaceMembers")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  token     String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  expiresAt DateTime
  revoked   Boolean  @default(false)
}
